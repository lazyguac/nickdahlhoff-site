---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const currentProjects = allProjects
  .filter(p => p.data.status === 'current')
  .sort((a, b) => a.data.order - b.data.order);

const featuredProject = allProjects.find(p => p.data.status === 'featured');

const archiveProjects = allProjects
  .filter(p => p.data.status === 'archive')
  .sort((a, b) => a.data.order - b.data.order);

function shortenYear(yr: string): string {
  return yr
    .replace(/(\d{2})(\d{2})–(\d{2})(\d{2})/g, (_, c1, y1, c2, y2) =>
      c1 === c2 ? `${c1}${y1}–${y2}` : `${c1}${y1}–${c2}${y2}`)
    .replace(/(\d{4}),\s*(\d{2})(\d{2})/g, (_, first, c2, y2) =>
      `${first}, ${y2}`)
    .replace(/–present/, '–');
}
---

<BaseLayout title="Nick Dahlhoff">
  <div class="page">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-left">
        <h1>Nick Dahlhoff</h1>
        <p class="hero-sub">Background in content marketing and digital businesses. Now building AI products and helping small businesses improve their systems.</p>
      </div>
      <div class="hero-right">
        <a href="#consulting" class="consulting-link">Open for consulting &rarr;</a>
        <span class="hero-location">Grand Rapids, MI</span>
      </div>
    </section>

    <!-- Current Projects -->
    <section class="current-grid">
      {currentProjects.map(project => (
        <a href={`/projects/${project.id}`} class="current-card">
          <div class="current-header">
            <h2 class="current-title">{project.data.title}</h2>
            {project.data.badge && (
              <span class="current-badge">{project.data.badge}</span>
            )}
          </div>
          <p class="current-tagline">{project.data.tagline}</p>
        </a>
      ))}
    </section>

    <!-- ALR Featured -->
    {featuredProject && (
      <a href={`/projects/${featuredProject.id}`} class="alr-section">
        <div class="alr-left">
          <span class="alr-title">All Language Resources</span>
          <span class="alr-dates">Built '16 &middot; Sold '21</span>
        </div>
        <div class="alr-right">
          <p class="alr-description">Started reviewing Chinese learning apps while teaching in Beijing. Grew it into a 20+ language affiliate site — content strategy, team of six writers, email funnels, affiliate partnerships, YouTube, and custom ad systems. Sold in 2021 for $960,000.</p>
        </div>
      </a>
    )}

    <!-- The Winding Road -->
    <section class="archive-section">
      <span class="archive-label">The winding road</span>
      <div class="archive-list">
        {archiveProjects.map(project => (
          <a href={`/projects/${project.id}`} class="archive-row">
            <div class="archive-bar"></div>
            <span class="archive-name">{project.data.title}</span>
            <span class="archive-desc">{project.data.tagline}</span>
            <span class="archive-year">{shortenYear(project.data.year)}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 1240px;
    margin: 0 auto;
    padding: 60px 100px;
    display: flex;
    flex-direction: column;
  }

  /* Hero */
  .hero {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-text);
  }

  .hero-sub {
    font-family: var(--font-serif);
    font-size: 18px;
    font-style: italic;
    line-height: 1.4;
    color: var(--color-accent-gold);
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    flex-shrink: 0;
    padding-top: 8px;
  }

  .consulting-link {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 18px;
    color: var(--color-accent-green);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .consulting-link:hover {
    color: var(--color-accent-green-dark);
  }

  .hero-location {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 16px;
    color: var(--color-text-muted);
  }

  /* Current Projects */
  .current-grid {
    display: flex;
    gap: 24px;
    width: 100%;
    margin-top: 40px;
  }

  .current-card {
    flex: 1 1 0%;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px 32px;
    border: 1px solid var(--color-border);
    border-left: 5px solid var(--color-accent-green);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .current-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    text-decoration: none;
  }

  .current-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .current-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    line-height: 34px;
    color: var(--color-text);
    margin: 0;
  }

  .current-badge {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 14px;
    color: var(--color-accent-green-dark);
  }

  .current-tagline {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-body);
  }

  /* ALR Section */
  .alr-section {
    display: flex;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    margin-top: 40px;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .alr-section:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    text-decoration: none;
  }

  .alr-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex-shrink: 0;
    width: 280px;
    padding: 32px 36px;
    gap: 8px;
    background: var(--color-accent-olive);
  }

  .alr-title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-card-dark-text);
  }

  .alr-dates {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 16px;
    color: var(--color-card-dark-subtle);
  }

  .alr-right {
    display: flex;
    align-items: center;
    flex-grow: 1;
    padding: 28px 40px;
    background: var(--color-olive-bg);
  }

  .alr-description {
    font-family: var(--font-serif);
    font-size: 17px;
    font-style: italic;
    line-height: 1.65;
    color: var(--color-text-overlay);
  }

  /* Archive Section */
  .archive-section {
    display: flex;
    flex-direction: column;
    margin-top: 48px;
    width: 100%;
  }

  .archive-label {
    font-family: var(--font-serif);
    font-size: 15px;
    font-style: italic;
    line-height: 18px;
    color: var(--color-text-muted);
    margin-bottom: 16px;
  }

  .archive-list {
    display: flex;
    flex-direction: column;
  }

  .archive-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
  }

  .archive-row:last-child {
    border-bottom: none;
  }

  .archive-row:hover {
    background: rgba(0,0,0,0.02);
    text-decoration: none;
  }

  .archive-bar {
    width: 3px;
    height: 32px;
    background: var(--color-text);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .archive-name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    line-height: 22px;
    color: var(--color-text);
    width: 240px;
    flex-shrink: 0;
  }

  .archive-desc {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 16px;
    color: var(--color-text-body);
    flex: 1 1 0%;
  }

  .archive-year {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 16px;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .page {
      padding: 60px 40px;
    }

    .hero h1 {
      font-size: 52px;
    }

    .archive-name {
      width: 180px;
    }
  }

  @media (max-width: 768px) {
    .page {
      padding: 40px 20px;
    }

    .hero {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    .hero h1 {
      font-size: 40px;
    }

    .hero-right {
      align-items: flex-start;
      padding-top: 0;
    }

    .current-grid {
      flex-direction: column;
      margin-top: 32px;
    }

    .alr-section {
      flex-direction: column;
      margin-top: 32px;
    }

    .alr-left {
      width: 100%;
      padding: 24px 28px;
    }

    .alr-right {
      padding: 24px 28px;
    }

    .archive-section {
      margin-top: 36px;
    }

    .archive-row {
      flex-wrap: wrap;
      gap: 8px 16px;
      padding: 16px 12px;
    }

    .archive-name {
      width: auto;
      flex: 1;
    }

    .archive-year {
      order: -1;
      width: auto;
    }

    .archive-desc {
      width: 100%;
      flex-basis: 100%;
      padding-left: 19px;
    }
  }
</style>
