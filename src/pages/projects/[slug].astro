---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const statusLabels: Record<string, string> = {
  current: 'Active',
  featured: 'Sold',
  archive: 'Archive',
};

const { latestUpdate, heroImage, tech, skills } = project.data;
const hasTechOrSkills = (tech && tech.length > 0) || (skills && skills.length > 0);
---

<BaseLayout title={`${project.data.title} — Nick Dahlhoff`} description={project.data.tagline}>
  <article class="project-page">
    <div class="container">
      <a href="/" class="back-link">&larr; Back</a>

      <header class={`project-header ${heroImage ? 'has-hero' : ''}`}>
        <div class="header-text">
          <div class="project-meta">
            <span class="project-year">{project.data.year}</span>
            <span class="project-status">{statusLabels[project.data.status]}</span>
          </div>
          <h1>{project.data.title}</h1>
          <p class="project-tagline">{project.data.tagline}</p>
          {project.data.url && (
            <a href={project.data.url} class="project-url" target="_blank" rel="noopener">
              Visit site &rarr;
            </a>
          )}
        </div>
        {heroImage && (
          <div class="hero-image">
            <img src={heroImage} alt="" />
          </div>
        )}
      </header>

      {latestUpdate && (
        <div class="latest-update">
          <span class="update-label">Latest update</span>
          <span class="update-date">{latestUpdate.date}</span>
          <p class="update-summary">{latestUpdate.summary}</p>
          <a href="#updates" class="update-link">See all updates &darr;</a>
        </div>
      )}

      <div class="project-content">
        <Content />
      </div>

      {hasTechOrSkills && (
        <footer class="project-footer">
          {skills && skills.length > 0 && (
            <div class="footer-section">
              <h3>Skills</h3>
              <div class="tag-list">
                {skills.map((s: string) => <span class="skill-tag">{s}</span>)}
              </div>
            </div>
          )}
          {tech && tech.length > 0 && (
            <div class="footer-section">
              <h3>Built with</h3>
              <div class="tag-list">
                {tech.map((t: string) => <span class="tech-tag">{t}</span>)}
              </div>
            </div>
          )}
        </footer>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .project-page {
    padding: var(--space-xl) 0 var(--space-3xl);
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .project-header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .project-header.has-hero {
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
  }

  .project-header.has-hero .header-text {
    flex: 1;
    min-width: 0;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .project-year {
    font-size: 0.875rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .project-status {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .project-header h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-sm);
  }

  .project-tagline {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .project-url {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent-gold);
  }

  /* Hero image */
  .hero-image {
    flex-shrink: 0;
    width: 360px;
  }

  .hero-image img {
    width: 100%;
    border-radius: 8px;
    background: var(--color-text);
    display: block;
  }

  @media (max-width: 768px) {
    .project-header.has-hero {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .hero-image {
      width: 100%;
    }
  }

  /* Latest update teaser */
  .latest-update {
    border-left: 3px solid var(--color-accent-gold);
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-xl);
    background: var(--color-border);
    border-radius: 0 6px 6px 0;
  }

  .update-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-gold);
    margin-right: var(--space-sm);
  }

  .update-date {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .update-summary {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-xs);
  }

  .update-link {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent-gold);
  }

  /* Markdown content styling */
  .project-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .project-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .project-content :global(p) {
    margin-bottom: var(--space-md);
    color: var(--color-text);
    line-height: 1.75;
    max-width: 65ch;
  }

  .project-content :global(ul),
  .project-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
    max-width: 65ch;
  }

  .project-content :global(li) {
    margin-bottom: var(--space-sm);
    line-height: 1.6;
  }

  .project-content :global(strong) {
    font-weight: 600;
  }

  .project-content :global(img) {
    width: 100%;
    max-width: 720px;
    border-radius: 8px;
    background: var(--color-border);
    margin: var(--space-lg) 0;
    display: block;
    border: 1px solid var(--color-border);
  }

  .project-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  /* Footer — skills & tech */
  .project-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .footer-section {
    margin-bottom: var(--space-lg);
  }

  .footer-section h3 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .skill-tag {
    font-size: 0.8rem;
    padding: 4px 12px;
    background: var(--color-text);
    color: var(--color-card-dark-text);
    border-radius: 4px;
    font-weight: 500;
  }

  .tech-tag {
    font-size: 0.75rem;
    padding: 2px 8px;
    background: var(--color-border);
    border-radius: 4px;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .project-header h1 {
      font-size: 1.75rem;
    }
  }
</style>
